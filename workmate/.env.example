# WorkMate Environment Configuration

# LLM Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Embeddings
# Set to 'local' for sentence-transformers, or 'openai' for text-embedding-3-small
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=your-openai-api-key-here-if-using-openai

# Database
# Default is SQLite for local development
DB_URL=sqlite:///./workmate.db
# Uncomment to use PostgreSQL:
# DB_URL=postgresql://user:password@localhost/workmate

# Vector Database
CHROMA_PERSIST_DIR=./data/chroma

# RAG configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RAG_CONFIDENCE_THRESHOLD=0.3

# Memory
MEMORY_IMPORTANCE_THRESHOLD=0.7
